{
  "name": "cache-seeder",
  "version": "2.2.0",
  "description": "This is worker that responsible execute seed&clean job for mapproxy redis caches wrapping mapproxy-utils package",
  "main": "./src/index.ts",
  "scripts": {
    "test:unit": "jest --config=./tests/configurations/unit/jest.config.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prelint:fix": "npm run format:fix",
    "prelint": "npm run format",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "release": "standard-version",
    "test": "tsc --noEmit && npm run test:unit",
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json && npm run assets:copy",
    "start": "npm run build && cd dist && node --import ./instrumentation.mjs ./index.js",
    "start:dev": "npm run build && cd dist && cross-env CONFIG_OFFLINE_MODE=true node --enable-source-maps --import ./instrumentation.mjs ./index.js",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles ./package.json dist",
    "clean": "rimraf dist",
    "prepare": "node .husky/install.mjs"
  },
  "directories": {
    "test": "tests"
  },
  "author": "MapColonies",
  "license": "ISC",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@godaddy/terminus": "^4.12.1",
    "@map-colonies/config": "^4.0.1",
    "@map-colonies/error-express-handler": "^4.0.0",
    "@map-colonies/error-types": "^1.3.1",
    "@map-colonies/express-access-log-middleware": "^4.1.0",
    "@map-colonies/js-logger": "^5.0.0",
    "@map-colonies/mc-priority-queue": "9.1.2",
    "@map-colonies/mc-utils": "6.0.1",
    "@map-colonies/prometheus": "^1.0.0",
    "@map-colonies/read-pkg": "^1.0.0",
    "@map-colonies/schemas": "^1.18.0",
    "@map-colonies/telemetry": "^6.0.0",
    "@map-colonies/tracing": "^1.0.0",
    "@map-colonies/tracing-utils": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@turf/buffer": "^7.2.0",
    "compression": "^1.8.0",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^17.6.6",
    "@faker-js/faker": "^9.2.0",
    "@map-colonies/eslint-config": "^8.0.0",
    "@map-colonies/prettier-config": "^1.0.0",
    "@map-colonies/standard-version-update-helm-version": "^2.0.1",
    "@map-colonies/tsconfig": "^2.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.7",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.8",
    "@types/lodash": "^4.14.191",
    "@types/node": "^24.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jest": "^29.15.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "jest-extended": "^6.0.0",
    "jest-html-reporters": "^3.1.7",
    "nock": "^13.5.0",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3"
  },
  "//OverrideComment": "https://github.com/Turfjs/turf/issues/2922",
  "overrides": {
    "concaveman": "1.2.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
